# NSW Government API credentials
# Register at https://api.nsw.gov.au/Account/Register
# Create an app and subscribe to the Trades, High Risk Work, and Asbestos APIs
NSW_API_KEY=your_consumer_key_here
NSW_API_SECRET=your_consumer_secret_here

# Feature flags
# Set to "true" to show the /api-config route and nav link (default: off)
VITE_ENABLE_API_CONFIG=false

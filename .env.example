# NSW Government API credentials
# Register at https://api.nsw.gov.au/Account/Register
# Create one app per API and subscribe to: Trades Licence, High Risk Work Register, Asbestos & Demolition Register

# Trades Licence API (NSW Fair Trading)
TRADES_API_KEY=your_trades_consumer_key_here
TRADES_API_SECRET=your_trades_consumer_secret_here

# High Risk Work Register API (SafeWork NSW)
HRW_API_KEY=your_hrw_consumer_key_here
HRW_API_SECRET=your_hrw_consumer_secret_here

# Asbestos & Demolition Register API (SafeWork NSW)
ASBESTOS_API_KEY=your_asbestos_consumer_key_here
ASBESTOS_API_SECRET=your_asbestos_consumer_secret_here

# Supabase (frontend auth)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# API base URL
# Leave blank for web (uses relative /api/check calls via same-origin)
# For Capacitor mobile builds, set to your deployed GCP Cloud Run URL:
#   VITE_API_BASE_URL=https://your-service.run.app
VITE_API_BASE_URL=

# GCP Cloud Run origin (production only)
# Set to the exact URL of your Cloud Run service to allow CORS from it
# Example: CLOUD_RUN_ORIGIN=https://your-service-abc123-uc.a.run.app
CLOUD_RUN_ORIGIN=

# Feature flags
# Set to "true" to show the /api-config route and nav link (default: off)
VITE_ENABLE_API_CONFIG=false

# E2E test credentials (Playwright)
# Create a dedicated test account in your Supabase project
# Add TEST_EMAIL and TEST_PASSWORD as GitHub secrets for CI
TEST_EMAIL=test@example.com
TEST_PASSWORD=your_test_password_here
INVALID_EMAIL=invalid@example.com
INVALID_PASSWORD=wrongpassword

# Logging
# Options: trace, debug, info, warn, error, fatal (default: info)
LOG_LEVEL=info
